{
    "compilerOptions": {
        "target": "ES6",
        "lib": ["es5", "es6"],
        "module": "commonjs",
        "moduleResolution": "node",
        "sourceMap": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "removeComments": false,
        "isolatedModules": true,
        "noImplicitAny": true,
        "outDir": "build"
    },
    "include": ["src/**/*.ts", ],
    "exclude": [
        "node_modules",
        "build"
    ]
}